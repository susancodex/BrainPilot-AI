# ── BrainPilot AI — Development Environment ───────────────────────────────────
# Copy this file to backend/.env for local development.
# All values here are safe defaults for a local dev setup.

# ── Core ──────────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=dev-secret-key-change-before-production
DEBUG=True

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://brainpilot:password@localhost:5432/brainpilot_dev

# ── AI Providers ──────────────────────────────────────────────────────────────
# At minimum GEMINI_API_KEY is required. Fallback providers are optional in dev.
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# Groq (fallback 1) — https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# OpenRouter (fallback 2) — https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# ── Redis / Celery ────────────────────────────────────────────────────────────
# Not required in development — Celery runs tasks synchronously (CELERY_TASK_ALWAYS_EAGER=True)
REDIS_URL=redis://localhost:6379/0

# ── Server ────────────────────────────────────────────────────────────────────
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000
FRONTEND_URL=http://localhost:5000

# ── Email ─────────────────────────────────────────────────────────────────────
# In dev, emails are printed to the console (EMAIL_BACKEND = console)
# — no SMTP credentials needed
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@brainpilot.ai
