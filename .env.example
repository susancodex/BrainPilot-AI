# ── BrainPilot AI — Frontend env ──────────────────────────────────────────────
# Port the Vite dev server listens on (keep at 5000 — Replit proxies this port)
PORT=5000

# Base path for the frontend
BASE_PATH=/

# ── Backend env lives in backend/.env.example ─────────────────────────────────
# The frontend Vite dev server proxies /api/* → localhost:8000 (Django).
# See backend/.env.example for all backend environment variables.
