# ── BrainPilot AI — Production Environment ────────────────────────────────────
# Copy to .env on your production server and fill in ALL values.
# Never commit the filled .env file to version control.
#
# Secret key generation:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

# ── Core ──────────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=CHANGE_ME_50_random_chars_minimum
DEBUG=False

# ── Database ──────────────────────────────────────────────────────────────────
# Full connection string — set automatically on Render from the DB resource
DATABASE_URL=postgresql://brainpilot:CHANGE_ME@db-host:5432/brainpilot_db

# ── AI Providers ──────────────────────────────────────────────────────────────
# Gateway tries providers in order: Gemini → Groq → OpenRouter
GEMINI_API_KEY=CHANGE_ME
GEMINI_MODEL=gemini-2.5-flash
GROQ_API_KEY=CHANGE_ME
OPENROUTER_API_KEY=CHANGE_ME

# ── Redis / Celery ────────────────────────────────────────────────────────────
# Set automatically on Render from the Redis resource
REDIS_URL=redis://redis-host:6379/0

# ── Server ────────────────────────────────────────────────────────────────────
# Comma-separated; on Render, leave empty — platform injects the service hostname
ALLOWED_HOSTS=brainpilot.ai,api.brainpilot.ai
CORS_ALLOWED_ORIGINS=https://brainpilot.ai
FRONTEND_URL=https://brainpilot.ai
# Set false if your load balancer/CDN terminates TLS (Render, Cloudflare, etc.)
SECURE_SSL_REDIRECT=false

# ── Docker (docker-compose.prod.yml only) ─────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@brainpilot.ai
EMAIL_HOST_PASSWORD=CHANGE_ME_smtp_app_password
DEFAULT_FROM_EMAIL=BrainPilot AI <noreply@brainpilot.ai>
