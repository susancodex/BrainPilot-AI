# ── BrainPilot AI — Staging Environment ───────────────────────────────────────
# Copy this file to .env on your staging server and fill in all values.
# Staging mirrors production but may use smaller/cheaper infrastructure.

# ── Core ──────────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=CHANGE_ME_generate_with_python_management_command
DEBUG=False

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://brainpilot:CHANGE_ME@db-host:5432/brainpilot_staging

# ── AI Providers ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=CHANGE_ME
GEMINI_MODEL=gemini-2.5-flash
GROQ_API_KEY=CHANGE_ME
OPENROUTER_API_KEY=CHANGE_ME

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis-host:6379/0

# ── Server ────────────────────────────────────────────────────────────────────
ALLOWED_HOSTS=staging.brainpilot.ai,staging-api.brainpilot.ai
CORS_ALLOWED_ORIGINS=https://staging.brainpilot.ai
CORS_ALLOWED_ORIGIN_REGEXES=
FRONTEND_URL=https://staging.brainpilot.ai
SECURE_SSL_REDIRECT=false   # Set true if your load balancer doesn't terminate TLS

# ── Docker (docker-compose.prod.yml) ─────────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=staging@brainpilot.ai
EMAIL_HOST_PASSWORD=CHANGE_ME
DEFAULT_FROM_EMAIL=noreply@brainpilot.ai
