modules = ["nodejs-20", "web", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "BrainPilot Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "BrainPilot Frontend"

[[workflows.workflow]]
name = "BrainPilot Backend"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash backend/run_dev.sh"
waitForPort = 5000

[[workflows.workflow]]
name = "BrainPilot Frontend"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/brainpilot-web run dev"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["python_gemini_ai_integrations:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 3001
externalPort = 3002

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 23630
externalPort = 3000

[[ports]]
localPort = 25585
externalPort = 3001

[nix]
channel = "stable-25_05"
packages = ["freetype", "lcms2", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "tcl", "tk", "zlib"]

[userenv]

[userenv.shared]
DJANGO_SECRET_KEY = "&abu#o%9p*o7l-ib@=22yv^!m6u1+s=gk828zi5d0qgw+mh*gb"
DJANGO_SETTINGS_MODULE = "config.settings.development"
PORT = "3001"
BASE_PATH = "/"
