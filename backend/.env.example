# ── Required ──────────────────────────────────────────────────────────────────

# Django secret key — generate with:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/brainpilot_db

# Google Gemini API key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Groq API key (AI fallback 1) — https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# OpenRouter API key (AI fallback 2) — https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# ── AI Tuning (optional) ──────────────────────────────────────────────────────
# Default: gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash

# ── Server (optional) ────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.development
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
SECURE_SSL_REDIRECT=false

# ── Celery / Redis (not required in dev — tasks run synchronously) ────────────
REDIS_URL=redis://localhost:6379/0

# ── Email ────────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@brainpilot.ai
