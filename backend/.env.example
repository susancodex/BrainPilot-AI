# ── BrainPilot AI — Backend Environment Variables ─────────────────────────────
# Copy this file to backend/.env for local development.
# On Render, set these in the service → Environment tab.
#
# Generate DJANGO_SECRET_KEY:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

# ── Required ───────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-generate-a-real-key-at-least-50-chars

# ── Database ───────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string (get from neon.tech → your project → Connection string)
# Format: postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
# Leave blank in local dev — SQLite is used automatically.
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/brainpilot?sslmode=require

# ── AI Providers (at least one required for AI features) ──────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
# GROQ_API_KEY=your-groq-api-key-here         # optional AI fallback 1
# OPENROUTER_API_KEY=your-openrouter-key-here # optional AI fallback 2

# ── AI Model Tuning (optional) ─────────────────────────────────────────────────
# GEMINI_MODEL=gemini-2.5-flash

# ── Auth ───────────────────────────────────────────────────────────────────────
# Production defaults to true; override here for local testing
REQUIRE_EMAIL_VERIFICATION=false

# ── Django server ──────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.development

# ── CORS + CSRF (production only — set to your Vercel frontend URL) ────────────
# ALLOWED_HOSTS=brainpilot-api.onrender.com
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
# CSRF_TRUSTED_ORIGINS=https://your-app.vercel.app,https://brainpilot-api.onrender.com
# FRONTEND_URL=https://your-app.vercel.app

# ── Security (production only) ─────────────────────────────────────────────────
# SECURE_SSL_REDIRECT=false

# ── Celery / Redis (not required in dev — tasks run synchronously) ─────────────
# REDIS_URL=redis://localhost:6379/0
# CELERY_ALWAYS_EAGER=true

# ── Email (optional — console backend used if not set) ────────────────────────
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-gmail-app-password
# DEFAULT_FROM_EMAIL=noreply@brainpilot.ai
