# ── BrainPilot AI — Frontend Environment Variables ────────────────────────────
#
# Copy this file to .env.local for local development.
# For Render static-site deploys, set these in the Render dashboard.
#
# IMPORTANT: Only VITE_ prefixed variables are exposed to the browser.
# Never put secrets (API keys, passwords) here.

# Backend API base URL.
# Leave blank (or omit) when Django serves the frontend from the same origin.
# Set to your backend Render URL when deploying the frontend as a separate static site.
# Example: https://brainpilot-api.onrender.com/api/v1
VITE_API_URL=

# Base path for the app (leave as / unless deployed to a sub-path).
BASE_PATH=/
