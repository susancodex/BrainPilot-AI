# ── BrainPilot AI — Frontend Environment Variables ────────────────────────────
# Copy this file to .env.local for local development.
# On Vercel, set these in Project → Settings → Environment Variables.
#
# IMPORTANT: Only VITE_ prefixed variables are exposed to the browser.
# Never put secrets (API keys, passwords) here.

# ── API Backend URL ────────────────────────────────────────────────────────────
# The Render backend origin — no trailing slash, no /api/v1 suffix.
#
# Local dev:  leave blank — the Vite dev server proxy forwards /api → localhost:8000
# Production: set to your Render service URL
#
# Example: VITE_API_URL=https://brainpilot-api.onrender.com
VITE_API_URL=

# ── Base path (leave as / unless deployed to a sub-path) ──────────────────────
BASE_PATH=/
